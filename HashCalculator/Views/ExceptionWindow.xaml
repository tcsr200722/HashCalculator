<Window
    x:Class="HashCalculator.ExceptionWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:HashCalculator"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="异常中断"
    Width="{Binding ExceptionWindowWidth, Source={x:Static local:Settings.Current}, Mode=TwoWay}"
    Height="{Binding ExceptionWindowHeight, Source={x:Static local:Settings.Current}, Mode=TwoWay}"
    d:DataContext="{d:DesignInstance Type=local:ExceptionWindowModel}"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <Grid Margin="8,8,8,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0">
            <TextBlock
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Style="{StaticResource TextBlockTitle}"
                Text="以下为前 10 条未捕获的异常，程序即将退出..." />
            <TextBlock
                Margin="0,4,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Style="{StaticResource TextBlockDefaultSecLight}"
                Text="问题反馈：点击底部任意按钮复制异常内容，在打开的浏览器页面登录后新建 Issue 并粘贴发布。" />
            <TextBlock
                Margin="0,4,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Style="{StaticResource TextBlockDefaultSecLight}"
                Text="如果复制失败请手动全选以下信息并复制，打开“设置→关于软件→问题反馈”手动打开问题反馈页面。" />
        </StackPanel>
        <TextBox
            Grid.Row="1"
            Margin="0,4,0,0"
            Padding="8"
            VerticalContentAlignment="Top"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="4"
            Foreground="{StaticResource SecondaryTextBrush}"
            HorizontalScrollBarVisibility="Auto"
            IsReadOnly="True"
            Text="{Binding StackTraceMessage, Mode=OneWay}"
            VerticalScrollBarVisibility="Auto" />
        <StackPanel
            Grid.Row="2"
            Margin="0,8,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Grid.Column="0"
                Padding="16,0"
                HorizontalAlignment="Right"
                Command="{Binding FeedbackCommand}"
                CommandParameter="{Binding Content, RelativeSource={RelativeSource Mode=Self}}"
                Content="复制并到 GitHub 反馈"
                Style="{StaticResource ButtonPrimary}" />
            <Button
                Grid.Column="1"
                Margin="8,0,0,0"
                Padding="16,0"
                HorizontalAlignment="Left"
                Command="{Binding FeedbackCommand}"
                CommandParameter="{Binding Content, RelativeSource={RelativeSource Mode=Self}}"
                Content="复制并到 Gitee 反馈"
                Style="{StaticResource ButtonPrimary}" />
        </StackPanel>
    </Grid>
</Window>
